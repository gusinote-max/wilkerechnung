# ============================================================
# Candis-Kopie – Produktions-Umgebungsvariablen
# Datei kopieren: cp .env.example .env
# Dann Werte anpassen!
# ============================================================

# --- MongoDB (wird von docker-compose mit internem Service-Namen überschrieben) ---
# Nicht ändern, sofern Sie nicht eine externe MongoDB nutzen!
MONGO_URL=mongodb://mongo:27017/invoice_management
DB_NAME=invoice_management

# --- JWT-Sicherheit ---
# UNBEDINGT ändern! Mindestens 32 zufällige Zeichen.
# Generator: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=BITTE-AENDERN-langer-geheimer-schluessel-min-32-zeichen

# --- OpenRouter API Key (für KI-OCR und E-Mail-KI-Analyse) ---
# Erhältlich unter: https://openrouter.ai/keys
# Ohne diesen Key ist keine KI-Rechnungsanalyse möglich!
OPENROUTER_API_KEY=sk-or-v1-IhrenKeyHierEintragen
